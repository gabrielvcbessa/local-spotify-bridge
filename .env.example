SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://localhost:8090/v1/auth/callback
SPOTIFY_SCOPES=user-read-playback-state user-modify-playback-state playlist-read-private playlist-read-collaborative user-library-read
DATA_PATH=data/bridge-state.json
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:8090

# Optional server tuning
HOST=0.0.0.0
PORT=8090
POLL_INTERVAL_SECONDS=3
STATE_CHANGE_PROGRESS_DRIFT_MS=5000

# Optional MQTT publishing
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=local-spotify-bridge
MQTT_KNOB_TOPIC_PREFIX=rotary
MQTT_KNOB_DEVICE_ID=knob
MQTT_QOS=1
MQTT_KNOB_ART_SIZE=180
MQTT_KNOB_ART_SWAP=lvgl
MQTT_KNOB_ART_VARIANT=player-bg
